<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <meta name="theme-color" content="#ffe9f1" />
  <title>Cindy Care</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Mali:wght@400;500;600;700&family=Quicksand:wght@500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css?v=15" />
</head>
<body>
  <div class="app">

    <!-- ============ TOPBAR ============ -->
    <header class="topbar">
      <div class="topbar-left">
        <div class="avatar" id="catAvatar">๐ฑ</div>
        <div>
          <div class="brand">Cindy Care</div>
          <div class="brand-sub" id="brandSub">เธเนเธญเธ Cindy</div>
        </div>
      </div>
      <div class="topbar-right">
        <button class="round-btn" id="darkBtn" title="เนเธซเธกเธ”เธกเธทเธ”/เธชเธงเนเธฒเธ">๐</button>
        <button class="round-btn" id="settingsBtn" title="เธ•เธฑเนเธเธเนเธฒ">โ๏ธ</button>
      </div>
    </header>

    <main class="views">
      <!-- ============ HOME / DASHBOARD ============ -->
      <section class="view active" id="view-home">
        <!-- greeting -->
        <div class="hero">
          <div class="hero-avatar" id="heroAvatar">๐ฑ</div>
          <div>
            <div class="hero-greet" id="heroGreet">เธชเธงเธฑเธชเธ”เธตเธ•เธญเธเน€เธเนเธฒ</div>
            <div class="hero-name">Cindy</div>
            <div class="hero-date" id="heroDate"></div>
          </div>
        </div>

        <!-- today's meals -->
        <section class="block">
          <div class="block-head"><h2>๐ฝ เธกเธทเนเธญเธงเธฑเธเธเธตเน</h2><span class="block-sub" id="mealsProgress"></span></div>
          <div id="todayMeals"></div>
        </section>

        <!-- daily recommendation -->
        <section class="block">
          <div class="block-head"><h2>๐’ก เนเธเธฐเธเธณเธงเธฑเธเธเธตเน</h2></div>
          <div class="card" id="recCard"></div>
        </section>

        <!-- nutrition score -->
        <section class="block">
          <div class="block-head"><h2>โค๏ธ เธเธฐเนเธเธเนเธ เธเธเธฒเธเธฒเธฃ</h2></div>
          <div class="card score-card" id="scoreCard"></div>
        </section>

        <!-- open package -->
        <section class="block">
          <div class="block-head"><h2>๐“ฆ เนเธเนเธเธ—เธตเนเน€เธเธดเธ”เธญเธขเธนเน</h2></div>
          <div class="card" id="openPackCard"></div>
        </section>

        <!-- tomorrow -->
        <section class="block">
          <div class="block-head"><h2>๐“… เธเธฃเธธเนเธเธเธตเน</h2></div>
          <div class="card" id="tomorrowCard"></div>
        </section>

        <!-- AI summary -->
        <section class="block">
          <div class="block-head"><h2>๐ค– เธชเธฃเธธเธเธงเธฑเธเธเธตเน</h2></div>
          <div class="card ai-card" id="aiCard"></div>
        </section>

        <!-- running low -->
        <section class="block">
          <div class="block-head"><h2>๐’ เนเธเธฅเนเธซเธกเธ”</h2></div>
          <div class="card" id="lowCard"></div>
        </section>
      </section>

      <!-- ============ CALENDAR ============ -->
      <section class="view" id="view-calendar">
        <div class="page-head">
          <button class="round-btn" id="calPrev">โ€น</button>
          <h1 class="page-title" id="calLabel">เธเธเธดเธ—เธดเธ</h1>
          <button class="round-btn" id="calNext">โ€บ</button>
        </div>
        <div class="card cal-card">
          <div class="cal-weekdays" id="calWeekdays"></div>
          <div class="cal-grid" id="calGrid"></div>
        </div>
        <div class="card" id="calForecast"></div>
      </section>

      <!-- ============ FOOD LIBRARY ============ -->
      <section class="view" id="view-food">
        <h1 class="page-title">๐ฑ เธเธฅเธฑเธเธญเธฒเธซเธฒเธฃ</h1>
        <div class="seg" id="foodTabs"></div>
        <div class="row-btns">
          <button class="btn-primary" id="addFoodBtn">๏ผ เน€เธเธดเนเธกเธญเธฒเธซเธฒเธฃ</button>
          <button class="btn-soft" id="batchBtn">๏ผ เธซเธฅเธฒเธขเธฃเธฒเธขเธเธฒเธฃ</button>
        </div>
        <div class="prod-grid" id="foodGrid"></div>
      </section>

      <!-- ============ SHOPPING ============ -->
      <section class="view" id="view-shop">
        <h1 class="page-title">๐’ เธฃเธฒเธขเธเธฒเธฃเธเธทเนเธญ</h1>
        <div class="card" id="shopNeed"></div>
        <div class="card" id="shopStats"></div>
        <div class="card" id="shopHistory"></div>
      </section>

      <!-- ============ HEALTH ============ -->
      <section class="view" id="view-health">
        <h1 class="page-title">๐’— เธชเธธเธเธ เธฒเธ</h1>
        <div class="card" id="healthSummary"></div>
        <div class="card" id="trendCard"></div>
        <div class="card" id="waterCard"></div>
        <div class="card">
          <div class="block-head"><h2>โ–๏ธ เธเนเธณเธซเธเธฑเธ (เธเธ.)</h2></div>
          <canvas id="weightChart" height="160"></canvas>
          <div class="inline-add">
            <input type="number" step="0.1" id="weightInput" placeholder="เน€เธเนเธ 3.7" />
            <button class="btn-primary slim" id="addWeightBtn">เธเธฑเธเธ—เธถเธ</button>
          </div>
        </div>
        <div class="card">
          <div class="block-head"><h2>๐ฝ เธเธฑเธเธ–เนเธฒเธขเธงเธฑเธเธเธตเน</h2></div>
          <div class="poop-row" id="poopRow"></div>
          <div id="poopHistory" class="mini-log"></div>
        </div>
        <div class="card" id="peeCard"></div>
        <div class="card" id="medCard"></div>
        <div class="card" id="vetCard"></div>
      </section>
    </main>

    <!-- ============ BOTTOM NAV ============ -->
    <nav class="tabbar">
      <button class="tab active" data-view="home"><span>๐ </span>เธงเธฑเธเธเธตเน</button>
      <button class="tab" data-view="calendar"><span>๐“…</span>เธเธเธดเธ—เธดเธ</button>
      <button class="tab" data-view="food"><span>๐ฑ</span>เธญเธฒเธซเธฒเธฃ</button>
      <button class="tab" data-view="shop"><span>๐’</span>เธเนเธญเธ</button>
      <button class="tab" data-view="health"><span>๐’—</span>เธชเธธเธเธ เธฒเธ</button>
    </nav>
  </div>

  <!-- ============ MODAL ============ -->
  <div class="modal-overlay" id="modalOverlay">
    <div class="modal" id="modalBox">
      <button class="modal-x" id="modalClose">โ•</button>
      <div id="modalContent"></div>
    </div>
  </div>

  <div class="toast" id="toast"></div>
  <script src="script.js?v=15"></script>
</body>
</html>

